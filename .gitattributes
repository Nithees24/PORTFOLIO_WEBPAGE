# Normalize line endings so they don't depend on each machine's git config.
# Text files are stored as LF in the repo and kept as LF in the working tree,
# which matches the current files and silences the core.autocrlf LF->CRLF
# warning on Windows.
* text=auto eol=lf

# Binary assets: never apply line-ending or text processing to these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.mp4  binary
*.pdf  binary
*.ttf  binary
*.woff binary
*.woff2 binary
